---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Qronex AI">

    <main role="main">
        <h1>Qronex AI</h1>
        <div class="container">
            <div class="input-response-row">
                <textarea
                id="promptInput"
                placeholder="Enter your prompt here..."
                rows="5"
                aria-label="Prompt input"
                ></textarea>
                <div id="responseContainer" role="region" aria-live="polite" aria-atomic="true"></div>
            </div>
            <button id="generateBtn" aria-live="polite">Generate</button>
        </div>
    </main>

    <style>
        body {
            font-family: 'fredoka', sans-serif;
            background: linear-gradient(135deg, #1a1a2e, #121224);
            margin: 0;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 2rem;
            color: #d8b4fe;
            }
            .container {
            background: #1f1b2e;
            border-radius: 1rem;
            box-shadow: 0 8px 24px rgba(138, 91, 226, 0.7);
            max-width: 1000px;
            width: 100%;
            padding: 2rem 3rem;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2rem;
            }
            .input-response-row {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 3rem;
            width: 100%;
            justify-content: center;
            }
            h1 {
            font-size: 3rem;
            font-weight: 700;
            margin-bottom: 3rem;
            text-align: center;
            color: #a78bfa;
            }
            textarea {
            width: 320px;
            font-size: 1.3rem;
            padding: 1.75rem 2.5rem;
            border: 2px solid #8a5be2;
            border-radius: 1rem;
            background: #2e2650;
            color: #e0d7ff;
            resize: vertical;
            box-shadow: inset 0 2px 6px rgba(138, 91, 226, 0.5);
            transition: border-color 0.3s ease, box-shadow 0.3s ease;
            min-height: 180px;
            display: block;
            margin-left: 0;
            margin-right: 0;
            }
            textarea:focus {
            outline: none;
            border-color: #a78bfa;
            box-shadow: 0 0 8px rgba(167, 139, 250, 0.7);
            background: #3b2f5a;
            }
            button {
            margin-top: 0;
            padding: 1.25rem 3.5rem;
            font-size: 1.6rem;
            font-weight: 700;
            color: #fff;
            background: linear-gradient(90deg, #9a6ef8, #ff7eb9);
            border: none;
            border-radius: 1.25rem;
            cursor: pointer;
            box-shadow: 0 8px 24px rgba(138, 91, 226, 0.9);
            transition: background 0.3s ease, box-shadow 0.3s ease, transform 0.2s ease;
            display: block;
            margin-left: auto;
            margin-right: auto;
            align-self: center;
            }
            button:hover:not(:disabled) {
            background: linear-gradient(90deg, #ff69b4, #8a5be2);
            box-shadow: 0 8px 25px rgba(255, 105, 180, 0.9);
            transform: translateY(-2px);
            }
            button:active:not(:disabled) {
            transform: translateY(0);
            box-shadow: 0 4px 12px rgba(255, 105, 180, 0.7);
            }
            button:disabled {
            background: #a78bfa;
            cursor: not-allowed;
            box-shadow: none;
            color: #d8b4fe;
            }
            #responseContainer {
            margin-top: 0;
            white-space: pre-wrap;
            background: #2e2650;
            padding: 1.75rem 2.5rem;
            border-radius: 1rem;
            box-shadow: 0 6px 16px rgba(138, 91, 226, 0.6);
            min-height: 5rem;
            color: #e0d7ff;
            font-size: 1.1rem;
            line-height: 1.6;
            opacity: 0;
            transform: translateY(10px);
            transition: opacity 0.4s ease, transform 0.4s ease;
            width: 320px;
            margin: 0;
            }
            #responseContainer.visible {
            opacity: 1;
            transform: translateY(0);
            }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
        let promptInput = document.getElementById('promptInput');
        let generateBtn = document.getElementById('generateBtn');
        let responseContainer = document.getElementById('responseContainer');

        if (!(promptInput instanceof HTMLTextAreaElement) || !(generateBtn instanceof HTMLButtonElement) || !(responseContainer instanceof HTMLDivElement)) {
            console.error('Required elements not found or incorrect types');
            return;
        }

        generateBtn.disabled = false;

        function generateContent() {
            const prompt = (promptInput as HTMLTextAreaElement).value.trim();
            if (!prompt) {
            alert('Please enter a prompt.');
            return;
            }
            generateBtn.disabled = true;
            generateBtn.textContent = 'Generating...';
            responseContainer.classList.remove('visible');
            responseContainer.textContent = '';

            fetch('http://localhost:5000/generate', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ prompt }),
            })
            .then(res => res.json())
            .then(data => {
                if (data.response) {
                responseContainer.textContent = data.response;
                } else {
                responseContainer.textContent = 'Error: ' + (data.error || 'Unknown error');
                }
            })
            .catch(error => {
                if (error instanceof Error) {
                responseContainer.textContent = 'Error: ' + error.message;
                } else {
                responseContainer.textContent = 'Error: ' + String(error);
                }
            })
            .finally(() => {
                responseContainer.classList.add('visible');
                generateBtn.disabled = false;
                generateBtn.textContent = 'Generate';
                (promptInput as HTMLTextAreaElement).value = '';
            });
        }

        generateBtn.addEventListener('click', generateContent);

        promptInput.addEventListener('keydown', (event) => {
            if (event.key === 'Enter' && !event.shiftKey) {
            event.preventDefault();
            generateContent();
            }
        });
        });
    </script>

</Layout>